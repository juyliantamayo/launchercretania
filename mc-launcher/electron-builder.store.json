{
  "appId": "LucerionGames.LucerionLauncher",
  "productName": "Lucerion Launcher",
  "asar": true,

  "extraMetadata": {
    "storeBuild": true
  },

  "directories": {
    "output": "dist/store",
    "buildResources": "store-assets"
  },

  "files": [
    "**/*",
    "!dist/**",
    "!__tests__/**",
    "!test-tmp-*/**",
    "!jest.config.*",
    "!electron-builder.store.json",
    "!scripts/**",
    "!*.pfx",
    "!*.pem",
    "!*.key",
    "!lucerion-dev.pfx",
    "!CHANGELOG-STORE.md",
    "!QA-CHECKLIST-STORE.md"
  ],

  "win": {
    "icon": "icon.ico",
    "certificateFile": "lucerion-store.pfx",
    "certificatePassword": "lucerion2026",
    "signingHashAlgorithms": ["sha256"],
    "rfc3161TimeStampServer": "http://timestamp.digicert.com",
    "target": [
      {
        "target": "appx",
        "arch": ["x64"]
      }
    ]
  },

  "appx": {
    "identityName": "LuceronStudios.LucerionLauncher",
    "publisherDisplayName": "Lucerion Studios",
    "publisher": "CN=D411C535-4983-481E-9A48-F4038813C746",
    "backgroundColor": "#1a2744",
    "artifactName": "LucerionLauncher-Store.msix",
    "applicationId": "LucerionLauncher",
    "displayName": "Lucerion Launcher",
    "showNameOnTiles": true,
    "minVersion": "10.0.17763.0"
  }
}
