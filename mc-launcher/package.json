{
  "name": "mc-launcher-cretania",
  "version": "1.0.0",
  "description": "Launcher Minecraft privado para Cretania",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest --verbose",
    "test:watch": "jest --watch --verbose",
    "build:win": "electron-builder --win portable",
    "build:all": "electron-builder --win --mac --linux"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "fs-extra": "^11.2.0",
    "minecraft-launcher-core": "^3.17.0",
    "msmc": "^5.0.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "jest": "^30.2.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.cretania.launcher",
    "productName": "Cretania Launcher",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!__tests__/**",
      "!test-tmp-*/**",
      "!jest.config.*"
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "CretaniaLauncher.exe"
    }
  }
}
