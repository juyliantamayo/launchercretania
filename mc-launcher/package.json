{
  "name": "mc-launcher-cretania",
  "version": "1.0.0",
  "description": "Launcher Minecraft privado para Cretania",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable",
    "build:all": "electron-builder --win --mac --linux"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "fs-extra": "^11.2.0",
    "minecraft-launcher-core": "^3.17.0",
    "msmc": "^5.0.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.cretania.launcher",
    "productName": "Cretania Launcher",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "CretaniaLauncher.exe"
    }
  }
}
