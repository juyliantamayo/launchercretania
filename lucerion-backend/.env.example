# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ─── MongoDB ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/lucerion

# ─── Seguridad ───────────────────────────────────────────────────────────────
# Clave JWT para el panel admin (cámbiala en producción)
JWT_SECRET=cambia-esta-clave-en-produccion

# Clave para cifrar manifest.enc (debe coincidir con CRETANIA_MANIFEST_SECRET del launcher)
MANIFEST_SECRET=cretania-manifest-2026-change-this-secret

# ─── Archivos ────────────────────────────────────────────────────────────────
# Carpeta donde se almacenan los JARs subidos
UPLOADS_DIR=./uploads

# ─── URL pública del backend (usada en baseUrl del manifiesto) ────────────────
# Ej: https://api.lucerion.net  (sin trailing slash)
PUBLIC_BASE_URL=http://localhost:3000
